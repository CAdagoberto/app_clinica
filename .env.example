# Opcional — sem isso no build, usa `extra.apiUrl` do app.json (produção: visaoderuastore.com.br).
# O app junta `/api/...`; não precise repetir `/api` aqui (se colocar .../api, o código ignora o sufixo).
#
# Produção:
# EXPO_PUBLIC_API_URL=https://visaoderuastore.com.br
#
# Dev local (Expo na mesma máquina que o servidor):
EXPO_PUBLIC_API_URL=http://127.0.0.1:4000

# Opcional — alinhar com DATA_REFERENCIA do servidor (.env do server)
EXPO_PUBLIC_DATA_REFERENCIA=2026-04-20
